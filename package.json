{
  "name": "gsc",
  "private": true,
  "version": "0.0.10",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "npm run icons && vite",
    "build": "tsc && cross-env VITE_BASE=/ vite build",
    "build:pages": "tsc && vite build",
    "preview": "vite preview",
    "preview:pages": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "test:e2e:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e:fixtures": "node e2e/fixtures/generate-audio-fixtures.mjs && node e2e/fixtures/generate-video-fixtures.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "icons": "vite-node --script scripts/sync-favicon.ts",
    "version:sync": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs",
    "screenshots": "node scripts/screenshots/capture.mjs",
    "screenshots:serve": "node scripts/screenshots/capture.mjs --serve",
    "tauri": "tauri",
    "tauri:dev": "npm run icons && tauri dev",
    "tauri:dev:ndi": "npm run icons && tauri dev --features ndi",
    "prepare": "husky"
  },
  "dependencies": {
    "@elemaudio/core": "^4.0.1",
    "@elemaudio/web-renderer": "^4.0.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "fflate": "^0.8.3",
    "i18next": "^26.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "tauri-plugin-keepawake-api": "^0.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "ffmpeg-static": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "puppeteer": "^25.0.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  }
}
