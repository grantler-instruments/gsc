{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grantler Stage Control",
  "version": "0.1.0",
  "identifier": "com.grantler-instruments.gsc",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421/gsc-app/",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grantler Stage Control",
        "url": "app/index.html",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
